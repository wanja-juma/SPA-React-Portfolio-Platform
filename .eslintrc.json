{
  "env": {
    "browser": true,
    "es2021": true
  },

  "extends": [
    "eslint:recommended",
    "plugin:react/recommended"
  ],

  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },

  "settings": {
    "react": {
      "version": "detect"
    }
  },

  "overrides": [
    {
      "files": ["**/*.test.*", "**/__tests__/**/*"],
      "rules": {
    "no-unused-vars": "off"
      },
        "globals": {
      "test": "readonly",
      "expect": "readonly",
      "describe": "readonly",
      "vi": "readonly"
    },
      "env": {
        "vitest-globals/env": true
      },
      "plugins": ["vitest-globals"],
      "extends": ["plugin:vitest-globals/recommended"]
    }
  ]
}